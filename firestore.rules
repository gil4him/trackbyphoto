rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Super-admin: the one Google account that runs the deployment can read
    // every memo and the admin counters. Email is signed into the auth token,
    // so this is a single fixed identity, not a role flag in Firestore.
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email == 'zymer4him@gmail.com';
    }

    // Each authenticated user can read/write their own memos.
    // memos/{memoId} doc has field `uid` set by the Cloud Function when it
    // creates the memo from the uploaded photo's storage path.
    match /memos/{memoId} {
      allow read:   if isAdmin()
                    || (request.auth != null && resource.data.uid == request.auth.uid);
      allow create: if false; // only Cloud Functions (admin SDK) create memos
      allow update, delete: if request.auth != null && resource.data.uid == request.auth.uid;
    }

    // User settings (recipients, cadence, etc) live under users/{uid}.
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
      allow read: if isAdmin();
    }

    // Running totals + per-day Gemini cost rollups, written by the Cloud
    // Function (admin SDK bypasses rules) and read by the /superadmin page.
    match /admin_totals/{doc} {
      allow read:  if isAdmin();
      allow write: if false;
    }
    match /admin_daily/{doc} {
      allow read:  if isAdmin();
      allow write: if false;
    }

    // Runtime config (currently just the active model). Admin reads + writes
    // directly from the dashboard so model can be flipped without a deploy.
    match /admin_config/{doc} {
      allow read, write: if isAdmin();
    }
  }
}
