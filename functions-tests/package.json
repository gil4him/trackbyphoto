{
  "name": "functions-tests",
  "private": true,
  "type": "module",
  "description": "Integration tests for the caregiver-share Cloud Functions, run against the Firestore emulator via firebase-functions-test.",
  "scripts": {
    "test": "firebase emulators:exec --only firestore --project demo-trackbyphoto 'vitest run'",
    "test:watch": "firebase emulators:exec --only firestore --project demo-trackbyphoto 'vitest'"
  },
  "devDependencies": {
    "firebase-admin": "^13.10.0",
    "firebase-functions": "^7.2.5",
    "firebase-functions-test": "^3.4.1",
    "vitest": "^3.0.5"
  }
}
