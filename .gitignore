.DS_Store
._*
.claude/
node_modules/

# env / secrets
.env
.env.local
.env.*.local
# Firebase v2 functions env files: .env.{projectId}
functions/.env
functions/.env.*

# build output
dist/
app/dist/
functions/lib/
# Local Capacitor plugin ships its built TS so the React app can import it
# directly without forcing CI to run an extra build step.
!app/plugins/on-device-vision/dist/

# logs
*.log
firebase-debug.log
firestore-debug.log
ui-debug.log
pglite-debug.log

# firebase cache
.firebase/

# Capacitor iOS — keep the Xcode project + Podfile in the repo, but ignore
# CocoaPods install output and Xcode build artifacts.
app/ios/App/Pods/
app/ios/App/build/
app/ios/App/DerivedData/
app/ios/App/App/public/
app/ios/App/App/capacitor.config.json
app/ios/.gradle/
xcuserdata/
*.xcworkspace/xcuserdata/
