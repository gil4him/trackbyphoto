# Copy to .env.local and fill in. Get values from:
#   firebase apps:sdkconfig WEB <appId> --project <projectId>
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

VITE_USE_EMULATOR=0

# KakaoTalk share — register the app at https://developers.kakao.com,
# add https://trackbyphoto.web.app to "사이트 도메인" under
# 내 애플리케이션 → 앱 설정 → 플랫폼 → Web, then activate "카카오 로그인"
# is NOT required (Share works without login). Paste the JavaScript key here.
VITE_KAKAO_JS_KEY=
