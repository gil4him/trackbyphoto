# Fastfile — the recipes ("lanes") that build and ship the app.
# Run from the app/ folder, e.g.  bundle exec fastlane beta_ios
#
# Lanes:
#   beta_ios        build + sign iOS, upload to TestFlight (tester builds)
#   beta_android    build a signed AAB, upload to Play "internal" track
#   release_ios     build + upload to the App Store (no auto-submit)
#   release_android build + upload to the Play "production" track
#   beta / release  do both platforms at once

# ── Shared: build the web app and copy it into the native project ─────────────
# Capacitor wraps our React/Vite site, so before any native build we rebuild the
# web bundle and sync it into ios/ or android/. Keeps native builds current.
def sync_web(platform)
  Dir.chdir("..") do                      # step up from app/fastlane to app/
    sh("npm", "run", "build")
    sh("npx", "cap", "sync", platform)
  end
end

# A unique, always-increasing build number (timestamp in minutes) so each upload
# is accepted by Apple/Google without us hand-bumping versions.
def unique_build_number
  (Time.now.to_i / 60).to_s
end

# ── iOS auth: App Store Connect API key (a passwordless way to talk to Apple) ──
def asc_api_key
  app_store_connect_api_key(
    key_id: ENV["ASC_KEY_ID"],
    issuer_id: ENV["ASC_ISSUER_ID"],
    key_filepath: ENV["ASC_KEY_PATH"],
    in_house: false
  )
end

# ── Android signing: passed straight to Gradle so we don't edit build.gradle ──
def android_signing
  {
    "android.injected.signing.store.file"     => ENV["ANDROID_KEYSTORE_PATH"],
    "android.injected.signing.store.password" => ENV["ANDROID_KEYSTORE_PASSWORD"],
    "android.injected.signing.key.alias"      => ENV["ANDROID_KEY_ALIAS"],
    "android.injected.signing.key.password"   => ENV["ANDROID_KEY_PASSWORD"],
    "android.injected.version.code"           => (Time.now.to_i / 60)
  }
end

# ── iOS lanes ─────────────────────────────────────────────────────────────────

lane :beta_ios do
  sync_web("ios")
  key = asc_api_key
  increment_build_number(xcodeproj: "ios/App/App.xcodeproj", build_number: unique_build_number)
  build_app(
    workspace: "ios/App/App.xcworkspace",
    scheme: "App",
    export_method: "app-store",
    output_directory: "build/ios",
    clean: true
  )
  upload_to_testflight(api_key: key, skip_waiting_for_build_processing: true)
end

lane :release_ios do
  sync_web("ios")
  key = asc_api_key
  increment_build_number(xcodeproj: "ios/App/App.xcodeproj", build_number: unique_build_number)
  build_app(
    workspace: "ios/App/App.xcworkspace",
    scheme: "App",
    export_method: "app-store",
    output_directory: "build/ios",
    clean: true
  )
  upload_to_app_store(
    api_key: key,
    submit_for_review: false,   # uploads the build; you press "submit" in App Store Connect
    automatic_release: false,
    force: true,                # skip the HTML confirmation prompt
    skip_metadata: true,        # we ship the binary only; edit listing in the web console
    skip_screenshots: true,
    precheck_include_in_app_purchases: false
  )
end

# ── Android lanes (require `npx cap add android` to have been run once) ────────

lane :beta_android do
  sync_web("android")
  gradle(project_dir: "android", task: "clean")
  gradle(project_dir: "android", task: "bundle", build_type: "Release", properties: android_signing)
  upload_to_play_store(
    track: "internal",
    package_name: ENV["ANDROID_PACKAGE"],
    json_key: ENV["PLAY_JSON_KEY_PATH"],
    aab: "android/app/build/outputs/bundle/release/app-release.aab",
    skip_upload_metadata: true,
    skip_upload_images: true,
    skip_upload_screenshots: true
  )
end

lane :release_android do
  sync_web("android")
  gradle(project_dir: "android", task: "clean")
  gradle(project_dir: "android", task: "bundle", build_type: "Release", properties: android_signing)
  upload_to_play_store(
    track: "production",
    package_name: ENV["ANDROID_PACKAGE"],
    json_key: ENV["PLAY_JSON_KEY_PATH"],
    aab: "android/app/build/outputs/bundle/release/app-release.aab",
    skip_upload_metadata: true,
    skip_upload_images: true,
    skip_upload_screenshots: true
  )
end

# ── Do both platforms in one command ──────────────────────────────────────────

lane :beta do
  beta_ios
  beta_android
end

lane :release do
  release_ios
  release_android
end
