# Fastfile — the recipes ("lanes") that build and ship the app.
# Run from the app/ folder, e.g.  bundle exec fastlane beta_ios
#
# Lanes:
#   beta_ios        build + sign iOS, upload to TestFlight (tester builds)
#   beta_android    build a signed AAB, upload to Play "internal" track
#   release_ios     build + upload to the App Store (no auto-submit)
#   release_android build + upload to the Play "production" track
#   beta / release  do both platforms at once

# Keep our human-written fastlane/README.md (don't let fastlane overwrite it).
skip_docs

# ── Shared: build the web app and copy it into the native project ─────────────
# Capacitor wraps our React/Vite site, so before any native build we rebuild the
# web bundle and sync it into ios/ or android/. Keeps native builds current.
def sync_web(platform)
  Dir.chdir("..") do                      # step up from app/fastlane to app/
    sh("npm", "run", "build")
    # `cap sync` runs `pod install`. Run it OUTSIDE Fastlane's Bundler env, or
    # CocoaPods (its own Ruby) tries to load our fastlane Gemfile and dies with
    # "Could not find … in locally installed gems".
    cap = -> { sh("npx", "cap", "sync", platform) }
    if defined?(Bundler) && Bundler.respond_to?(:with_unbundled_env)
      Bundler.with_unbundled_env(&cap)
    elsif defined?(Bundler) && Bundler.respond_to?(:with_clean_env)
      Bundler.with_clean_env(&cap)
    else
      cap.call
    end
  end
end

# A unique, always-increasing build number (timestamp in minutes) so each upload
# is accepted by Apple/Google without us hand-bumping versions.
def unique_build_number
  (Time.now.to_i / 60).to_s
end

# ── iOS auth: App Store Connect API key (a passwordless way to talk to Apple) ──
def asc_api_key
  app_store_connect_api_key(
    key_id: ENV["ASC_KEY_ID"],
    issuer_id: ENV["ASC_ISSUER_ID"],
    key_filepath: ENV["ASC_KEY_PATH"],
    in_house: false
  )
end

# Install the distribution certificate + provisioning profile from the private
# "match" repo (decrypt-only, no Apple portal access needed). Runs both locally
# and on CI so signing is identical everywhere — no Xcode account required.
def ios_install_signing
  setup_ci if is_ci   # CI only: create a temporary keychain
  match(type: "appstore", readonly: true)
  # Xcode 15 reads profiles from ~/Library/MobileDevice/Provisioning Profiles;
  # Xcode 16+ from ~/Library/Developer/Xcode/UserData/Provisioning Profiles.
  # On CI, mirror whatever match installed into BOTH so xcodebuild finds it
  # regardless of the runner's Xcode version.
  if is_ci
    require "fileutils"
    dirs = [
      File.expand_path("~/Library/MobileDevice/Provisioning Profiles"),
      File.expand_path("~/Library/Developer/Xcode/UserData/Provisioning Profiles"),
    ]
    dirs.each { |d| FileUtils.mkdir_p(d) }
    profiles = dirs.flat_map { |d| Dir.glob(File.join(d, "*.mobileprovision")) }.uniq
    profiles.each do |src|
      dirs.each do |d|
        dst = File.join(d, File.basename(src))
        FileUtils.cp(src, dst) unless File.expand_path(src) == dst
      end
    end
  end
end

# The exact profile name match installed (handles match's auto-numbered names),
# with a sensible fallback. Used for both the archive and the export.
def ios_profile_name
  ENV["sigh_#{ENV['IOS_BUNDLE_ID']}_appstore_profile-name"] || "match AppStore #{ENV['IOS_BUNDLE_ID']}"
end

# Apply manual match signing to the App target ONLY. (Setting it globally also
# hits the CocoaPods library targets, which don't accept a provisioning profile
# and fail the archive.) Run after match so we use the exact profile name.
def ios_configure_signing
  update_code_signing_settings(
    path: "ios/App/App.xcodeproj",
    targets: ["App"],
    use_automatic_signing: false,
    team_id: ENV["APPLE_TEAM_ID"],
    code_sign_identity: "Apple Distribution",
    bundle_identifier: ENV["IOS_BUNDLE_ID"],
    profile_name: ios_profile_name
  )
end

# Build + sign + export an App Store .ipa with the match cert/profile.
def ios_build
  build_app(
    workspace: "ios/App/App.xcworkspace",
    scheme: "App",
    export_method: "app-store",
    output_directory: "build/ios",
    clean: true,
    export_options: {
      signingStyle: "manual",
      provisioningProfiles: { ENV["IOS_BUNDLE_ID"] => ios_profile_name }
    }
  )
end

# ── Android signing: passed straight to Gradle so we don't edit build.gradle ──
def android_signing
  {
    "android.injected.signing.store.file"     => ENV["ANDROID_KEYSTORE_PATH"],
    "android.injected.signing.store.password" => ENV["ANDROID_KEYSTORE_PASSWORD"],
    "android.injected.signing.key.alias"      => ENV["ANDROID_KEY_ALIAS"],
    "android.injected.signing.key.password"   => ENV["ANDROID_KEY_PASSWORD"],
    "android.injected.version.code"           => (Time.now.to_i / 60)
  }
end

# ── iOS lanes ─────────────────────────────────────────────────────────────────

lane :beta_ios do
  sync_web("ios")
  key = asc_api_key
  ios_install_signing
  ios_configure_signing
  increment_build_number(xcodeproj: "ios/App/App.xcodeproj", build_number: unique_build_number)
  ios_build
  upload_to_testflight(api_key: key, skip_waiting_for_build_processing: true)
end

lane :release_ios do
  sync_web("ios")
  key = asc_api_key
  ios_install_signing
  ios_configure_signing
  increment_build_number(xcodeproj: "ios/App/App.xcodeproj", build_number: unique_build_number)
  ios_build
  upload_to_app_store(
    api_key: key,
    submit_for_review: false,   # uploads the build; you press "submit" in App Store Connect
    automatic_release: false,
    force: true,                # skip the HTML confirmation prompt
    skip_metadata: true,        # we ship the binary only; edit listing in the web console
    skip_screenshots: true,
    precheck_include_in_app_purchases: false
  )
end

# ── Android lanes (require `npx cap add android` to have been run once) ────────

lane :beta_android do
  sync_web("android")
  gradle(project_dir: "android", task: "clean")
  gradle(project_dir: "android", task: "bundle", build_type: "Release", properties: android_signing)
  upload_to_play_store(
    track: "internal",
    package_name: ENV["ANDROID_PACKAGE"],
    json_key: ENV["PLAY_JSON_KEY_PATH"],
    aab: "android/app/build/outputs/bundle/release/app-release.aab",
    skip_upload_metadata: true,
    skip_upload_images: true,
    skip_upload_screenshots: true
  )
end

lane :release_android do
  sync_web("android")
  gradle(project_dir: "android", task: "clean")
  gradle(project_dir: "android", task: "bundle", build_type: "Release", properties: android_signing)
  upload_to_play_store(
    track: "production",
    package_name: ENV["ANDROID_PACKAGE"],
    json_key: ENV["PLAY_JSON_KEY_PATH"],
    aab: "android/app/build/outputs/bundle/release/app-release.aab",
    skip_upload_metadata: true,
    skip_upload_images: true,
    skip_upload_screenshots: true
  )
end

# ── Do both platforms in one command ──────────────────────────────────────────

lane :beta do
  beta_ios
  beta_android
end

lane :release do
  release_ios
  release_android
end
