# Copy this file to ".env" (same folder) and fill in the real values.
# Fastlane loads .env automatically. The real .env is gitignored — never commit
# it or the key files it points to.

# ── App identifiers (same value works for both stores) ───────────────────────
IOS_BUNDLE_ID=com.gil4him.trackbyphoto
ANDROID_PACKAGE=com.gil4him.trackbyphoto

# ── Apple / App Store Connect ────────────────────────────────────────────────
APPLE_ID=you@example.com          # your Apple Developer login email
APPLE_TEAM_ID=ABCDE12345          # Apple Developer → Membership → Team ID

# App Store Connect API key (App Store Connect → Users and Access → Integrations
# → App Store Connect API → generate a key, download the .p8 ONCE).
ASC_KEY_ID=XXXXXXXXXX
ASC_ISSUER_ID=00000000-0000-0000-0000-000000000000
ASC_KEY_PATH=./fastlane/AuthKey_XXXXXXXXXX.p8

# iOS signing via "match" (needed for the GitHub Actions / CI builds; local
# builds use Xcode automatic signing instead). The git repo privately stores
# your encrypted certificate + profile.
MATCH_GIT_URL=https://github.com/gil4him/shomery-certificates.git
MATCH_PASSWORD=a-strong-passphrase

# ── Google Play ──────────────────────────────────────────────────────────────
# A service-account JSON key with "Release" permission in the Play Console
# (Play Console → Users and permissions / Google Cloud → service account).
PLAY_JSON_KEY_PATH=./fastlane/play-key.json

# ── Android signing keystore (you generate this once with `keytool`) ─────────
ANDROID_KEYSTORE_PATH=./fastlane/upload-keystore.jks
ANDROID_KEYSTORE_PASSWORD=changeme
ANDROID_KEY_ALIAS=upload
ANDROID_KEY_PASSWORD=changeme
